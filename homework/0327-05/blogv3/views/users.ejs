<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>所有帳號</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 600px; margin: 50px auto; padding: 20px; }
    h1 { color: #333; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #f5f5f5; }
    a { color: #0066cc; }
  </style>
</head>
<body>
  <h1>所有帳號</h1>
  <% if (users.length === 0) { %>
    <p>尚無帳號。</p>
  <% } else { %>
    <table>
      <tr>
        <th>帳號</th>
        <th>密碼</th>
      </tr>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.username %></td>
          <td><%= u.password %></td>
        </tr>
      <% }) %>
    </table>
  <% } %>
  <p><a href="/">返回首頁</a> | <a href="/login">登入</a> | <a href="/register">註冊</a></p>
</body>
</html>