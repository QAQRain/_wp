<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>網誌</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 0; }
    .container { display: flex; max-width: 1200px; margin: 0 auto; padding: 20px; }
    .main { flex: 1; max-width: 800px; margin-right: 20px; }
    .sidebar { width: 250px; position: sticky; top: 20px; height: fit-content; }
    h1 { color: #333; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .post { border: 1px solid #ddd; padding: 15px; margin-bottom: 20px; border-radius: 5px; }
    .post h2 { margin-top: 0; }
    .post a { text-decoration: none; color: #0066cc; }
    .post .date { color: #888; font-size: 0.9em; }
    .post .author { color: #666; font-size: 0.9em; }
    .post .likes { color: #e74c3c; font-size: 0.9em; }
    .btn { display: inline-block; padding: 10px 20px; background: #0066cc; color: white; text-decoration: none; border-radius: 5px; }
    .btn-delete { background: #cc0000; }
    .btn-edit { background: #ff9900; margin-left: 5px; }
    .sidebar-box { background: #f8f9fa; padding: 15px; border-radius: 5px; border: 1px solid #ddd; }
    .sidebar-box h3 { margin-top: 0; color: #333; }
    .sidebar-post { padding: 10px 0; border-bottom: 1px solid #eee; }
    .sidebar-post:last-child { border-bottom: none; }
    .sidebar-post a { text-decoration: none; color: #0066cc; font-weight: bold; }
    .sidebar-post .author { font-size: 0.85em; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="main">
      <div class="header">
        <h1>我的網誌</h1>
        <div>
          <% if (user) { %>
            <span>歡迎, <%= user.username %></span>
            <a href="/new" class="btn">新增文章</a>
            <a href="/logout" class="btn" style="background: #666;">登出</a>
          <% } else { %>
            <a href="/login" class="btn">登入</a>
            <a href="/register" class="btn" style="background: #28a745;">註冊</a>
          <% } %>
        </div>
      </div>
      <% if (posts.length === 0) { %>
        <p>尚無文章。</p>
      <% } else { %>
        <% posts.forEach(post => { %>
          <div class="post">
            <h2><a href="/post/<%= post.id %>"><%= post.title %></a></h2>
            <p class="date"><%= new Date(post.created_at).toLocaleString('zh-TW') %></p>
            <% if (post.author_name) { %>
              <p class="author">作者: <%= post.author_name %></p>
            <% } %>
            <p class="likes">❤️ <%= post.like_count || 0 %> 個推薦</p>
            <% if (user && user.id === post.author_id) { %>
              <a href="/edit/<%= post.id %>" class="btn btn-edit">編輯</a>
              <form action="/delete/<%= post.id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-delete" onclick="return confirm('確定刪除？')">刪除</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      <% } %>
      <p><a href="/users">查看所有帳號</a></p>
    </div>
    <div class="sidebar">
      <div class="sidebar-box">
        <h3>🔥 熱門推薦</h3>
        <% if (recommended.length === 0) { %>
          <p>尚無推薦文章</p>
        <% } else { %>
          <% recommended.forEach(post => { %>
            <div class="sidebar-post">
              <a href="/post/<%= post.id %>"><%= post.title %></a>
              <% if (post.author_name) { %>
                <div class="author">作者: <%= post.author_name %></div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>