<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>網誌</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <div class="main">
      <div class="header">
        <a href="/" class="logo">
          <div class="logo-icon">B</div>
          <span>Blog</span>
        </a>
        <div>
          <% if (user) { %>
            <span style="margin-right: 10px;">歡迎, <a href="/user/<%= user.id %>" style="color: #4ecca3;"><%= user.username %></a></span>
            <a href="/new" class="btn">新增文章</a>
            <a href="/logout" class="btn btn-secondary">登出</a>
          <% } else { %>
            <a href="/login" class="btn">登入</a>
            <a href="/register" class="btn btn-secondary">註冊</a>
          <% } %>
        </div>
      </div>
      <% if (posts.length === 0) { %>
        <p>尚無文章。</p>
      <% } else { %>
        <% posts.forEach(post => { %>
          <div class="post">
            <h2><a href="/post/<%= post.id %>"><%= post.title %></a></h2>
            <p class="date"><%= new Date(post.created_at).toLocaleString('zh-TW') %></p>
            <% if (post.author_name) { %>
              <p class="author">作者: <a href="/user/<%= post.author_id %>"><%= post.author_name %></a></p>
            <% } %>
            <p class="likes">❤️ <%= post.like_count || 0 %> 個推薦</p>
            <% if (user && user.id === post.author_id) { %>
              <a href="/edit/<%= post.id %>" class="btn btn-edit">編輯</a>
              <form action="/delete/<%= post.id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-delete" onclick="return confirm('確定刪除？')">刪除</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      <% } %>
      <p><a href="/users">查看所有帳號</a></p>
    </div>
    <div class="sidebar">
      <div class="sidebar-box">
        <h3>🔥 熱門推薦</h3>
        <% if (recommended.length === 0) { %>
          <p>尚無推薦文章</p>
        <% } else { %>
          <% recommended.forEach(post => { %>
            <div class="sidebar-post">
              <a href="/post/<%= post.id %>"><%= post.title %></a>
              <% if (post.author_name) { %>
                <div class="author">作者: <%= post.author_name %></div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>